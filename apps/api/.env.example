# Local development example
# Copy to `apps/api/.env` and replace placeholder values.

NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-local-secret
ALLOW_PUBLIC_REGISTRATION=true
RESEND_API_KEY=

# Local Postgres for development
# Use a local database, not the VPS production database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/illustriober_local?schema=public

# Optional override used by the runtime Prisma client and Prisma CLI when set.
# Leave blank for local development unless you need a different direct connection.
DIRECT_DATABASE_URL=

# VPS production example
# Do not put production secrets in git. Set these only in the VPS environment manager.
# NODE_ENV=production
# PORT=4000
# CORS_ORIGIN=https://illustriober.com,https://www.illustriober.com
# JWT_SECRET=replace-with-a-long-random-production-secret
# ALLOW_PUBLIC_REGISTRATION=true
# RESEND_API_KEY=your-resend-key
# DIRECT_DATABASE_URL=postgresql://app_user:app_password@localhost:5432/illustrioberdb?schema=public
