generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL moved to prisma.config.ts
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}

enum EnquiryStatus {
  NEW
  REVIEWED
  RESPONDED
  CONVERTED   // became a client
  ARCHIVED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETE
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

enum TicketType {
  BUG
  FEATURE
  IDEA
  QUESTION
  SUPPORT
}

enum TicketStatus {
  OPEN
  IN_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MessageType {
  TEXT
  FILE
  SYSTEM     // automated messages (e.g. "Project marked complete")
}

enum FileCategory {
  DELIVERABLE
  ATTACHMENT
  REFERENCE
  INVOICE
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  passwordHash      String
  role              Role            @default(CLIENT)
  firstName         String
  lastName          String
  phone             String?
  avatarUrl         String?
  isActive          Boolean         @default(true)
  emailVerified     Boolean         @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  projects          Project[]     @relation("ClientProjects")
  tickets           Ticket[]      @relation("SubmittedTickets")
  comments          Comment[]
  messages          Message[]
  files             File[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  inviteTokens      InviteToken[]
  sentMessages      Message[]       @relation("SentMessages")

  @@index([email])
  @@index([role])
}

// ─────────────────────────────────────────
// AUTH TOKENS
// ─────────────────────────────────────────

model RefreshToken {
  id          String    @id @default(cuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([token])
}

model InviteToken {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  email       String
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([email])
}

// ─────────────────────────────────────────
// ENQUIRIES (Pre-account, public form)
// ─────────────────────────────────────────

model Enquiry {
  id              String        @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String?
  company         String?
  projectType     String        // "web app", "graphic design", "both", etc.
  description     String        @db.Text
  budgetRange     String?       // "Under $500", "$500-$2000", etc.
  timeline        String?       // "ASAP", "1-3 months", etc.
  referralSource  String?       // "Google", "referral", "social media"
  status          EnquiryStatus @default(NEW)
  adminNotes      String?       @db.Text
  convertedToId   String?       // userId if converted to client
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────

model Project {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String          @db.Text
  status          ProjectStatus   @default(PLANNING)
  clientId        String
  client          User            @relation("ClientProjects", fields: [clientId], references: [id])
  startDate       DateTime?
  estimatedEnd    DateTime?
  actualEnd       DateTime?
  repositoryUrl   String?
  stagingUrl      String?
  liveUrl         String?
  techStack       String[]        // ["React", "Node.js", "PostgreSQL"]
  totalBudget     Decimal?        @db.Decimal(12, 2)
  currency        String          @default("KES")
  isPublic        Boolean         @default(false)  // Show in portfolio
  coverImageUrl   String?
  adminNotes      String?         @db.Text
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  milestones      Milestone[]
  tickets         Ticket[]
  files           File[]
  messages        Message[]
  portfolioEntry  PortfolioEntry?

  @@index([clientId])
  @@index([status])
  @@index([slug])
}

// ─────────────────────────────────────────
// MILESTONES
// ─────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?         @db.Text
  order       Int             // Display order
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
  @@index([order])
}

// ─────────────────────────────────────────
// TICKETS
// ─────────────────────────────────────────

model Ticket {
  id          String          @id @default(cuid())
  title       String
  description String          @db.Text
  type        TicketType
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id])
  submittedById String
  submittedBy User            @relation("SubmittedTickets", fields: [submittedById], references: [id])
  assignedToId String?        // admin user
  resolvedAt  DateTime?
  adminNote   String?         @db.Text  // Internal only, not visible to client
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  comments    Comment[]
  files       File[]

  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([submittedById])
}

// ─────────────────────────────────────────
// COMMENTS (on tickets)
// ─────────────────────────────────────────

model Comment {
  id          String    @id @default(cuid())
  content     String    @db.Text
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  isInternal  Boolean   @default(false)  // Admin-only internal note
  editedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ticketId])
  @@index([authorId])
}

// ─────────────────────────────────────────
// MESSAGES (project-level comms thread)
// ─────────────────────────────────────────

model Message {
  id          String      @id @default(cuid())
  content     String      @db.Text
  type        MessageType @default(TEXT)
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id])
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String?     // null = broadcast to project
  readAt      DateTime?
  createdAt   DateTime    @default(now())

  // Back-relation to satisfy Prisma
  userRef     User?        @relation(fields: [senderId], references: [id], map: "MessageSenderRef")

  @@index([projectId])
  @@index([senderId])
}

// ─────────────────────────────────────────
// FILES
// ─────────────────────────────────────────

model File {
  id            String        @id @default(cuid())
  name          String
  originalName  String
  mimeType      String
  size          Int           // bytes
  url           String        // Cloudinary URL
  publicId      String        // Cloudinary public_id for deletion
  category      FileCategory  @default(ATTACHMENT)
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id])
  ticketId      String?
  ticket        Ticket?       @relation(fields: [ticketId], references: [id])
  uploadedById  String
  uploadedBy    User          @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime      @default(now())

  @@index([projectId])
  @@index([ticketId])
  @@index([uploadedById])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  link        String?   // e.g. "/dashboard/tickets/abc"
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
}

// ─────────────────────────────────────────
// PORTFOLIO (public showcase)
// ─────────────────────────────────────────

model PortfolioEntry {
  id            String    @id @default(cuid())
  projectId     String    @unique
  project       Project   @relation(fields: [projectId], references: [id])
  title         String
  summary       String    @db.Text
  coverImageUrl String
  images        String[]  // Additional screenshots
  tags          String[]  // ["React", "SaaS", "Fintech"]
  featured      Boolean   @default(false)
  order         Int       @default(0)
  clientApproved Boolean  @default(false)
  liveUrl       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([featured])
  @@index([order])
}
